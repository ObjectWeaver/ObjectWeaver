# LLM Management Configuration
# =============================
# This file contains all configuration options for the LLM management system.
# Choose your provider and configure accordingly.

# Provider Selection
# ------------------
# Options: "local", "openai", "gemini"
# - local: Use a local or custom OpenAI-compatible endpoint (e.g., Ollama, vLLM, LM Studio)
# - openai: Use the official OpenAI API with native SDK
# - gemini: Use Google's Gemini API with automatic format conversion
#
# NOTE: If LLM_PROVIDER is not set, it will auto-detect based on LLM_API_URL.
#       If LLM_API_URL is set, it assumes "local" provider.
#       Otherwise, you MUST explicitly set LLM_PROVIDER.
LLM_PROVIDER=local

# Local/Custom Provider Configuration
# ------------------------------------
# Required when LLM_PROVIDER=local
# Example endpoints:
# - Ollama: http://localhost:11434/v1/chat/completions
# - vLLM: http://localhost:8000/v1/chat/completions
# - LM Studio: http://localhost:1234/v1/chat/completions
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=optional-local-api-key

# OpenAI Configuration
# --------------------
# Required when LLM_PROVIDER=openai
# Uncomment and set your OpenAI API key:
# LLM_API_KEY=sk-proj-...

# Gemini Configuration
# --------------------
# Required when LLM_PROVIDER=gemini
# Uncomment and set your Gemini API key:
# LLM_API_KEY=your-gemini-api-key-here

# HTTP Client Configuration
# -------------------------
# Enable gzip compression for HTTP requests (reduces bandwidth)
# Note: Not applicable for OpenAI provider (uses native SDK)
LLM_USE_GZIP=false

# Rate Limiting Configuration
# ---------------------------
# Maximum tokens that can be processed per minute
# Adjust based on your API tier/limits
LLM_MAX_TOKENS_PER_MINUTE=150000000

# Maximum number of API requests per minute
# Adjust based on your API tier/limits
LLM_MAX_REQUESTS_PER_MINUTE=500

# Backoff Strategy Configuration
# ------------------------------
# How to handle rate limiting and transient errors
# Options:
# - "none": Simple fixed pause, no exponential backoff
# - "global": Exponential backoff that pauses all workers when rate limited
# - "per-worker": Exponential backoff applied to individual workers only
LLM_BACKOFF_STRATEGY=none

# Logging Configuration
# ---------------------
# Enable verbose logging for debugging
# Set to "true" to see detailed logs about rate limiting, backoff, retries, etc.
VERBOSE=false

# Example Configurations
# ======================

# Example 1: Local Ollama
# -----------------------
# LLM_PROVIDER=local
# LLM_API_URL=http://localhost:11434/v1/chat/completions
# LLM_API_KEY=
# LLM_MAX_REQUESTS_PER_MINUTE=100

# Example 2: OpenAI Production
# -----------------------------
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-proj-...
# LLM_MAX_TOKENS_PER_MINUTE=90000
# LLM_MAX_REQUESTS_PER_MINUTE=3500
# LLM_BACKOFF_STRATEGY=per-worker
# VERBOSE=false

# Example 3: Google Gemini
# -------------------------
# LLM_PROVIDER=gemini
# LLM_API_KEY=your-gemini-api-key
# LLM_MAX_TOKENS_PER_MINUTE=2000000
# LLM_MAX_REQUESTS_PER_MINUTE=1500
# LLM_BACKOFF_STRATEGY=global
# LLM_USE_GZIP=true

# Example 4: Custom vLLM Server
# ------------------------------
# LLM_PROVIDER=local
# LLM_API_URL=http://vllm-server.local:8000/v1/chat/completions
# LLM_API_KEY=custom-auth-token
# LLM_USE_GZIP=true
# LLM_MAX_REQUESTS_PER_MINUTE=200
# LLM_BACKOFF_STRATEGY=none
