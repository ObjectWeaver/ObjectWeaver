        "functionCount": {
          "low": 10,
          "medium": 20,
          "high": 30,
          "critical": 50
        },
        "dependencyCount": {
          "low": 5,
          "medium": 10,
          "high": 15,
          "critical": 25
        },
        "functionLength": {
          "low": 20,
          "medium": 40,
          "high": 60,
          "critical": 100
        },
        "parameterCount": {
          "low": 3,
          "medium": 5,
          "high": 7,
          "critical": 10
        }
      }
