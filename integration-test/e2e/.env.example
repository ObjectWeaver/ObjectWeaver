# Integration Test Environment Variables
# Copy this to .env and customize as needed

# Load Test Configuration
MAX_RPS=1000              # Maximum requests per second to ramp up to
DURATION=60s              # Total test duration
RAMP_UP_TIME=30s          # Time to reach MAX_RPS
BASE_URL=http://objectweaver:2008
PASSWORD=test-password

# Mock LLM Configuration
MOCK_LLM_PORT=8080
MOCK_LLM_MIN_DELAY_MS=10
MOCK_LLM_MAX_DELAY_MS=50

# ObjectWeaver Configuration
ENVIRONMENT=development
LLM_PROVIDER=openai
LLM_API_URL=http://mock-llm:8080/v1
LLM_API_KEY=mock-api-key

# Cache (Redis)
CACHE_ACTIVE=true
CACHE_ADDRESS=redis:6379
CACHE_PASSWORD=
CACHE_DB=0
CACHE_TTL_SECONDS=3600
